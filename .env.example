# Frontend EmailJS settings
# Copy this file to .env and replace the placeholder values with real values from the EmailJS dashboard.
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
# Set to true to show alerts on the contact form for debugging. Default is false.
VITE_SHOW_CONTACT_ALERTS=false
# If EmailJS is not configured, the form will open the user's email client via mailto.
